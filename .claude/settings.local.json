{
  "permissions": {
    "allow": [
      "Bash(if [ -d specs ])",
      "Bash(then ls -d specs/*-user-management)",
      "Bash(else echo \"specs directory does not exist\")",
      "Bash(fi)",
      "Bash(powershell.exe -Command \".specify/scripts/powershell/setup-plan.ps1 -Json\")",
      "Bash(powershell.exe -Command \".specify/scripts/powershell/check-prerequisites.ps1 -Json -RequireTasks -IncludeTasks\")",
      "Bash(if [ -d \"D:\\Workspace\\Battle\\specs\\001-user-management\\checklists\" ])",
      "Bash(then ls \"D:\\Workspace\\Battle\\specs\\001-user-management\\checklists\")",
      "Bash(else echo \"No checklists directory\")",
      "Bash(if [ -d \"D:\\Workspace\\BATL\\specs\\002-category-system\\checklists\" ])",
      "Bash(then ls \"D:\\Workspace\\BATL\\specs\\002-category-system\\checklists\")",
      "Bash(curl:*)",
      "Bash(npx prisma format:*)",
      "Bash(\"$USERPROFILE/bin/render.exe\":*)",
      "Bash(\"$USERPROFILE/bin/render.exe\" config get)",
      "Bash(\"$USERPROFILE/bin/render.exe\" whoami --output json)",
      "Bash(\"$USERPROFILE/bin/render.exe\" projects --output json)",
      "Bash(npm run lint)",
      "Bash(git show:*)",
      "Bash(xargs:*)",
      "Bash(find:*)",
      "Bash(if [ -f \"D:\\Workspace\\BATL\\specs\\008-tournament-rankings\\quickstart.md\" ])",
      "Bash(then echo \"quickstart.md exists\")",
      "Bash(else echo \"quickstart.md not found\")",
      "Bash(npm test:*)",
      "Bash(powershell.exe -NoProfile -Command 'Get-Command pwsh -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source; if \\($?\\) { pwsh --version }')",
      "Bash(winget install:*)",
      "Bash(powershell.exe -NoProfile -Command \"winget install Microsoft.PowerShell --accept-source-agreements --accept-package-agreements\")",
      "Bash(powershell.exe -NoProfile -Command \"& { Get-Command winget.exe -ErrorAction SilentlyContinue; [Environment]::GetEnvironmentVariable\\('LOCALAPPDATA'\\) + '\\\\Microsoft\\\\WindowsApps\\\\winget.exe' | ForEach-Object { Test-Path $_ } }\")",
      "Bash(powershell.exe -NoProfile -Command \"choco install powershell-core -y\")",
      "Bash(powershell.exe -NoProfile -Command \"Get-Command pwsh.exe -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source\")"
    ],
    "deny": [],
    "ask": []
  },
  "enabledMcpjsonServers": [
    "playwright",
    "chrome-devtools"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"${file}\" == */backend/src/*.js ]]; then cd backend && npx eslint --fix \"${file}\" 2>&1 || true; fi",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "if [[ \"${file}\" == */frontend/src/*.@(js|jsx) ]]; then cd frontend && npx eslint --fix \"${file}\" 2>&1 || true; fi",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"${file}\" == */backend/src/*.js ]]; then cd backend && npx eslint --fix \"${file}\" 2>&1 || true; fi",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "if [[ \"${file}\" == */frontend/src/*.@(js|jsx) ]]; then cd frontend && npx eslint --fix \"${file}\" 2>&1 || true; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
